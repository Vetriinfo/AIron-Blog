9:[["$","meta","0",{"name":"viewport","content":"width=device-width, initial-scale=1"}],["$","meta","1",{"charSet":"utf-8"}],["$","title","2",{"children":"RAG for Design Codes and Standards · Technical Creator Blog"}],["$","meta","3",{"name":"description","content":"Using retrieval-augmented generation to query building codes and standards—setup, chunking, and safety."}],["$","link","4",{"rel":"author","href":"https://yourdomain.com"}],["$","meta","5",{"name":"author","content":"Your Name"}],["$","meta","6",{"name":"robots","content":"index, follow"}],["$","link","7",{"rel":"canonical","href":"https://yourdomain.com/blog/rag-for-design-codes"}],["$","meta","8",{"property":"og:title","content":"RAG for Design Codes and Standards"}],["$","meta","9",{"property":"og:description","content":"Using retrieval-augmented generation to query building codes and standards—setup, chunking, and safety."}],["$","meta","10",{"property":"og:url","content":"https://yourdomain.com/blog/rag-for-design-codes"}],["$","meta","11",{"property":"og:image","content":"https://yourdomain.com/og-default.png"}],["$","meta","12",{"property":"og:image:alt","content":"RAG for Design Codes and Standards"}],["$","meta","13",{"property":"og:type","content":"article"}],["$","meta","14",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","15",{"name":"twitter:title","content":"RAG for Design Codes and Standards"}],["$","meta","16",{"name":"twitter:description","content":"Using retrieval-augmented generation to query building codes and standards—setup, chunking, and safety."}],["$","meta","17",{"name":"twitter:image","content":"https://yourdomain.com/og-default.png"}],["$","meta","18",{"name":"twitter:image:alt","content":"RAG for Design Codes and Standards"}]]
