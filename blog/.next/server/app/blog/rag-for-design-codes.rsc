a:[["$","p",null,{"className":"mb-4 leading-7 text-ink","children":["Design codes (AISC, ACI, ASCE, Eurocodes) are long, dense, and full of cross-references. ",["$","strong",null,{"children":"RAG"}]," (retrieval-augmented generation) can turn them into queryable knowledge bases for lookups and summaries—without replacing the need to read the actual document."]}],"\n",["$","h2",null,{"id":"what-rag-does-here","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"What RAG Does Here"}],"\n",["$","ol",null,{"className":"mb-4 ml-6 list-decimal space-y-1 text-ink","children":["\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Ingest"}],": Chunk the code PDF or text (by section, clause, or fixed size)."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Embed"}],": Store chunks in a vector store with embeddings."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Retrieve"}],": For a user question, find the most relevant chunks."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Generate"}],": Send those chunks plus the question to an LLM to produce an answer grounded in the text."]}],"\n"]}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":"The result: \"What does AISC 360 say about block shear?\" returns a short answer with the right section and key wording, instead of you scrolling the PDF."}],"\n",["$","h2",null,{"id":"chunking-strategy","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Chunking Strategy"}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":["Codes have hierarchy (chapter → section → clause). Prefer ",["$","strong",null,{"children":"semantic chunking"}]," that respects that structure so retrieval returns whole clauses or sub-clauses. Avoid splitting mid-sentence or mid-table."]}],"\n",["$","h2",null,{"id":"safety-and-liability","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Safety and Liability"}],"\n",["$","ul",null,{"className":"mb-4 ml-6 list-disc space-y-1 text-ink","children":["\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Never"}]," present RAG output as a substitute for reading the code. Always cite section numbers and encourage the user to verify."]}],"\n",["$","li",null,{"className":"leading-7","children":["Use ",["$","strong",null,{"children":"guardrails"}],": e.g., \"This is for reference only; confirm with the current printed code.\""]}],"\n",["$","li",null,{"className":"leading-7","children":["Prefer ",["$","strong",null,{"children":"conservative"}]," model behavior (stick to the retrieved text, avoid extrapolation)."]}],"\n"]}],"\n",["$","h2",null,{"id":"stack-sketch","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Stack Sketch"}],"\n",["$","ul",null,{"className":"mb-4 ml-6 list-disc space-y-1 text-ink","children":["\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Documents"}],": PDFs of the code (with permission / licensing in mind)."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Embeddings"}],": OpenAI, Cohere, or open-source (e.g., sentence-transformers)."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Vector store"}],": Pinecone, Weaviate, or local (Chroma, LanceDB)."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Orchestration"}],": LangChain, LlamaIndex, or custom pipelines."]}],"\n"]}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":["A later post will walk through a minimal ",["$","strong",null,{"children":"RAG pipeline"}]," for one code (e.g., AISC 360 Chapter D) and how to expose it as a simple API or chat UI."]}]]
