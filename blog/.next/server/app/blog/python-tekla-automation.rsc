a:[["$","p",null,{"className":"mb-4 leading-7 text-ink","children":["Tekla Structures exposes a .NET API that you can drive from C# or, with a little setup, from ",["$","strong",null,{"children":"Python"}]," via pythonnet. Here's a practical overview."]}],"\n",["$","h2",null,{"id":"why-python","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Why Python?"}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":"Many engineers already use Python for data, calcs, and scripts. Using it with Tekla lets you:"}],"\n",["$","ul",null,{"className":"mb-4 ml-6 list-disc space-y-1 text-ink","children":["\n",["$","li",null,{"className":"leading-7","children":"Reuse pandas, numpy, and your existing tooling"}],"\n",["$","li",null,{"className":"leading-7","children":"Run checks and exports in CI or on a server"}],"\n",["$","li",null,{"className":"leading-7","children":"Build one-off scripts without spinning up Visual Studio"}],"\n"]}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":"The tradeoff is a bit of setup (pythonnet, Tekla's .NET runtime) and sometimes slower iteration than C# in Visual Studio."}],"\n",["$","h2",null,{"id":"getting-started","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Getting Started"}],"\n",["$","ol",null,{"className":"mb-4 ml-6 list-decimal space-y-1 text-ink","children":["\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Install Tekla"}]," and ensure the Tekla Open API assemblies are available."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Install pythonnet"}]," (",["$","code",null,{"className":"rounded bg-surface-muted px-1.5 py-0.5 font-mono text-sm","children":"pip install pythonnet"}],")."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Reference the Tekla assemblies"}]," and connect to the running Tekla process or open a model."]}],"\n"]}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":"A minimal \"hello world\" might look like:"}],"\n",["$","pre",null,{"className":"mb-4 overflow-x-auto rounded-lg border border-border bg-surface-elevated p-4 text-sm","children":["$","code",null,{"className":"block language-python","children":"import clr\r\nclr.AddReference(\"Tekla.Structures.Model\")\r\nfrom Tekla.Structures.Model import Model\r\n\r\nmodel = Model()\r\nif model.GetConnectionStatus():\r\n    print(\"Connected to Tekla.\")\r\nelse:\r\n    print(\"Open a model in Tekla first.\")\n"}]}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":"From here you can enumerate model objects, read properties, and create or modify elements."}],"\n",["$","h2",null,{"id":"typical-use-cases","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Typical Use Cases"}],"\n",["$","ul",null,{"className":"mb-4 ml-6 list-disc space-y-1 text-ink","children":["\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Model enumeration"}],": Loop over beams, columns, or connections and extract IDs, profiles, and positions."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Batch property updates"}],": Change phase, name, or user-defined attributes in bulk."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Export to CSV/JSON"}],": Push model data into pandas for analysis or reporting."]}],"\n",["$","li",null,{"className":"leading-7","children":[["$","strong",null,{"children":"Drawing lists"}],": Query drawing objects and export titles and status."]}],"\n"]}],"\n",["$","h2",null,{"id":"next","className":"font-display mt-10 mb-3 text-xl font-semibold text-ink scroll-mt-20","children":"Next"}],"\n",["$","p",null,{"className":"mb-4 leading-7 text-ink","children":["We'll look at ",["$","strong",null,{"children":"C# vs Python"}]," for Tekla in a follow-up, and then ",["$","strong",null,{"children":"connection design checks"}]," driven from the model."]}]]
